{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "AI-SRE Engine",
  "tags": ["ai-sre", "kubernetes"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "severity",
        "type": "custom",
        "query": "critical, high, medium, low",
        "current": { "text": "All", "value": ".*" },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }
    ]
  },
  "panels": [
    {
      "title": "Total Incidents",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "ai_sre_incidents_total",
          "legendFormat": "incidents"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "LLM Calls",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "ai_sre_llm_calls_total",
          "legendFormat": "LLM calls"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Incidents by Severity",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "ai_sre_incidents_by_severity{severity=~\"$severity\"}",
          "legendFormat": "{{ severity }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Incidents Over Time",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "ai_sre_incidents_by_severity{severity=~\"$severity\"}",
          "legendFormat": "{{ severity }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "showPoints": "never" }
        }
      }
    },
    {
      "title": "Recent Incidents",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "ai_sre_incidents_by_severity{severity=~\"$severity\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": false, "__name__": true, "container": true, "endpoint": true, "instance": true, "job": true, "namespace": true, "pod": true, "service": true } } }
      ]
    }
  ]
}